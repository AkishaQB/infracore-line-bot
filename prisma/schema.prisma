// =====================================================
// Coupon & Loyalty Management System — Prisma Schema
// =====================================================

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// =====================================================
// Enums
// =====================================================

enum Role {
  SUPER_ADMIN
  MARKETING_ADMIN
  STORE_OPERATOR
}

enum CouponType {
  PERCENTAGE
  FIXED
  FREE_ITEM
  BOGO
  LOYALTY_REWARD
}

enum DiscountType {
  PERCENTAGE
  FIXED_AMOUNT
}

enum CouponStatus {
  ACTIVE
  INACTIVE
  EXPIRED
  DEPLETED
}

enum RedemptionStatus {
  PENDING
  COMPLETED
  FAILED
  CANCELLED
}

enum TriggerType {
  NEW_USER
  BIRTHDAY
  PURCHASE_MILESTONE
  INACTIVITY
  REFERRAL
  MANUAL
}

enum CampaignStatus {
  DRAFT
  ACTIVE
  PAUSED
  COMPLETED
}

enum CustomerTier {
  BRONZE
  SILVER
  GOLD
  PLATINUM
}

enum NotificationType {
  COUPON_ISSUED
  COUPON_EXPIRING
  REWARD_EARNED
  CAMPAIGN
  WELCOME
}

enum PointTransactionType {
  EARNED
  REDEEMED
  BONUS
  EXPIRED
  ADJUSTMENT
}

// =====================================================
// Models
// =====================================================

model Admin {
  id           String   @id @default(uuid())
  email        String   @unique
  passwordHash String   @map("password_hash")
  role         Role     @default(MARKETING_ADMIN)
  name         String
  isActive     Boolean  @default(true) @map("is_active")
  lastLoginAt  DateTime? @map("last_login_at")
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  @@map("admins")
}

model Customer {
  id            String       @id @default(uuid())
  lineUserId    String       @unique @map("line_user_id")
  displayName   String?      @map("display_name")
  pictureUrl    String?      @map("picture_url")
  statusMessage String?      @map("status_message")
  phone         String?
  email         String?
  birthday      DateTime?
  points        Int          @default(0)
  totalPoints   Int          @default(0) @map("total_points")
  tier          CustomerTier @default(BRONZE)
  isActive      Boolean      @default(true) @map("is_active")
  lastActiveAt  DateTime?    @map("last_active_at")
  createdAt     DateTime     @default(now()) @map("created_at")
  updatedAt     DateTime     @updatedAt @map("updated_at")

  // Relations
  couponAssignments CouponAssignment[]
  redemptions       Redemption[]
  loyaltyCards      LoyaltyCard[]
  notifications     Notification[]
  pointTransactions PointTransaction[]

  @@index([tier])
  @@index([isActive])
  @@map("customers")
}

model Store {
  id        String   @id @default(uuid())
  name      String
  code      String   @unique
  address   String?
  city      String?
  latitude  Float?
  longitude Float?
  phone     String?
  isActive  Boolean  @default(true) @map("is_active")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  // Relations
  redemptions   Redemption[]
  loyaltyStamps LoyaltyStamp[]

  @@map("stores")
}

model Coupon {
  id             String       @id @default(uuid())
  code           String       @unique
  type           CouponType
  title          String
  description    String?
  discountType   DiscountType? @map("discount_type")
  discountValue  Float?        @map("discount_value")
  minOrderAmount Float?        @map("min_order_amount")
  maxDiscount    Float?        @map("max_discount")
  imageUrl       String?       @map("image_url")
  termsConditions String?      @map("terms_conditions")
  startDate      DateTime      @map("start_date")
  expirationDate DateTime      @map("expiration_date")
  usageLimit     Int?          @map("usage_limit")
  usedCount      Int           @default(0) @map("used_count")
  perUserLimit   Int           @default(1) @map("per_user_limit")
  status         CouponStatus  @default(ACTIVE)
  isDeleted      Boolean       @default(false) @map("is_deleted")
  createdAt      DateTime      @default(now()) @map("created_at")
  updatedAt      DateTime      @updatedAt @map("updated_at")

  // Relations
  assignments CouponAssignment[]
  campaigns   Campaign[]

  @@index([status])
  @@index([expirationDate])
  @@index([type])
  @@map("coupons")
}

model CouponAssignment {
  id         String   @id @default(uuid())
  couponId   String   @map("coupon_id")
  customerId String   @map("customer_id")
  qrToken    String   @unique @map("qr_token")
  isRedeemed Boolean  @default(false) @map("is_redeemed")
  assignedAt DateTime @default(now()) @map("assigned_at")
  expiresAt  DateTime @map("expires_at")

  // Relations
  coupon     Coupon     @relation(fields: [couponId], references: [id], onDelete: Cascade)
  customer   Customer   @relation(fields: [customerId], references: [id], onDelete: Cascade)
  redemption Redemption?

  @@index([customerId, couponId])
  @@index([qrToken])
  @@index([isRedeemed])
  @@map("coupon_assignments")
}

model Campaign {
  id              String         @id @default(uuid())
  name            String
  description     String?
  triggerType     TriggerType     @map("trigger_type")
  targetAudience  Json?           @map("target_audience")
  couponId        String          @map("coupon_id")
  startDate       DateTime        @map("start_date")
  endDate         DateTime        @map("end_date")
  status          CampaignStatus  @default(DRAFT)
  isRecurring     Boolean         @default(false) @map("is_recurring")
  maxIssuances    Int?            @map("max_issuances")
  issuedCount     Int             @default(0) @map("issued_count")
  createdAt       DateTime        @default(now()) @map("created_at")
  updatedAt       DateTime        @updatedAt @map("updated_at")

  // Relations
  coupon Coupon @relation(fields: [couponId], references: [id], onDelete: Cascade)

  @@index([status, startDate, endDate])
  @@index([triggerType])
  @@map("campaigns")
}

model Redemption {
  id             String           @id @default(uuid())
  assignmentId   String           @unique @map("assignment_id")
  customerId     String           @map("customer_id")
  storeId        String?          @map("store_id")
  status         RedemptionStatus @default(PENDING)
  pointsEarned   Int              @default(0) @map("points_earned")
  transactionRef String?          @unique @map("transaction_ref")
  failureReason  String?          @map("failure_reason")
  redeemedAt     DateTime?        @map("redeemed_at")
  createdAt      DateTime         @default(now()) @map("created_at")
  updatedAt      DateTime         @updatedAt @map("updated_at")

  // Relations
  assignment CouponAssignment @relation(fields: [assignmentId], references: [id], onDelete: Cascade)
  customer   Customer         @relation(fields: [customerId], references: [id], onDelete: Cascade)
  store      Store?           @relation(fields: [storeId], references: [id])

  @@index([customerId])
  @@index([storeId])
  @@index([status])
  @@map("redemptions")
}

model LoyaltyCard {
  id             String   @id @default(uuid())
  customerId     String   @map("customer_id")
  name           String
  description    String?
  totalSlots     Int      @map("total_slots")
  filledSlots    Int      @default(0) @map("filled_slots")
  rewardCouponId String?  @map("reward_coupon_id")
  isCompleted    Boolean  @default(false) @map("is_completed")
  completedAt    DateTime? @map("completed_at")
  createdAt      DateTime @default(now()) @map("created_at")
  updatedAt      DateTime @updatedAt @map("updated_at")

  // Relations
  customer Customer       @relation(fields: [customerId], references: [id], onDelete: Cascade)
  stamps   LoyaltyStamp[]

  @@index([customerId])
  @@index([isCompleted])
  @@map("loyalty_cards")
}

model LoyaltyStamp {
  id        String   @id @default(uuid())
  cardId    String   @map("card_id")
  storeId   String?  @map("store_id")
  earnedAt  DateTime @default(now()) @map("earned_at")

  // Relations
  card  LoyaltyCard @relation(fields: [cardId], references: [id], onDelete: Cascade)
  store Store?      @relation(fields: [storeId], references: [id])

  @@index([cardId])
  @@map("loyalty_stamps")
}

model PointTransaction {
  id          String               @id @default(uuid())
  customerId  String               @map("customer_id")
  points      Int
  type        PointTransactionType
  description String?
  referenceId String?              @map("reference_id")
  createdAt   DateTime             @default(now()) @map("created_at")

  // Relations
  customer Customer @relation(fields: [customerId], references: [id], onDelete: Cascade)

  @@index([customerId])
  @@index([type])
  @@index([createdAt])
  @@map("point_transactions")
}

model Notification {
  id         String           @id @default(uuid())
  customerId String           @map("customer_id")
  type       NotificationType
  title      String
  body       String
  data       Json?
  isRead     Boolean          @default(false) @map("is_read")
  sentAt     DateTime         @default(now()) @map("sent_at")

  // Relations
  customer Customer @relation(fields: [customerId], references: [id], onDelete: Cascade)

  @@index([customerId, isRead])
  @@index([sentAt])
  @@map("notifications")
}
